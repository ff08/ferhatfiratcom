---
import Layout from "../Layout.astro";
import TopNav from "../TopNav.astro";
import Footer from "../Footer.astro";
import SectionCard from "../SectionCard.astro";
import Breadcrumb from "../Breadcrumb.astro";
import GlobalCta from "../GlobalCta.astro";
import { site } from "../../content/site";
import { ui, type Lang } from "../../content/i18n";

const { lang } = Astro.props as { lang: Lang };
const t = ui[lang];
const pageTitle = lang === "tr" ? "Haberler & Yazılar" : "News & Articles";
---

<Layout title={pageTitle} lang={lang}>
  <TopNav lang={lang} />
  <main class="container mt-10">
    <div class="mb-6">
      <Breadcrumb lang={lang} crumbs={[{ label: pageTitle }]} />
    </div>
    <div class="mb-8">
      <h1>{pageTitle}</h1>
      <p class="mt-3 max-w-3xl text-slate-600">
        {lang === "tr"
          ? "No‑Code / Low‑Code dünyasındaki güncellemeler, trendler ve pratik notlar."
          : "Updates, trends, and practical notes from the No‑Code / Low‑Code world."}
      </p>
    </div>

    <SectionCard title={lang === "tr" ? "Son yazılar" : "Latest posts"}>
      <div class="divide-y divide-slate-200">
        {site.articles.map((a) => (
          <a
            class="focus-ring block rounded-xl py-4 hover:bg-slate-50"
            href={lang === "tr" ? `/news/${a.slug}` : `/en/news/${a.slug}`}
          >
            <div class="flex flex-wrap items-center gap-2 text-xs text-slate-500">
              <span class="rounded-full bg-slate-100 px-2 py-0.5 font-semibold text-slate-700">{a.category}</span>
              <span>{a.dateISO}</span>
              {a.readingMinutes && <span>• {lang === "tr" ? `${a.readingMinutes} dk` : `${a.readingMinutes} min`}</span>}
            </div>
            <div class="mt-2 text-base font-semibold tracking-tight text-slate-900">{lang === "tr" ? a.titleTr : a.titleEn}</div>
            <div class="mt-1 text-sm text-slate-600">{lang === "tr" ? a.excerptTr : a.excerptEn}</div>
          </a>
        ))}
      </div>
    </SectionCard>

    <div class="mt-10 min-w-0">
      <GlobalCta lang={lang} />
    </div>
  </main>
  <Footer />
</Layout>

