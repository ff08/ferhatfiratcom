---
import Layout from "../Layout.astro";
import TopNav from "../TopNav.astro";
import Footer from "../Footer.astro";
import SectionCard from "../SectionCard.astro";
import Breadcrumb from "../Breadcrumb.astro";
import GlobalCta from "../GlobalCta.astro";
import Icon from "../Icon.astro";
import { site } from "../../content/site";
import { ui, type Lang } from "../../content/i18n";

const { lang } = Astro.props as { lang: Lang };
const t = ui[lang];
const pageTitle = lang === "tr" ? "Referanslar" : "References";

function safeHost(href: string): string {
  try {
    return new URL(href).host;
  } catch {
    return href;
  }
}

function pseudoYears(seed: string): number {
  let h = 0;
  for (let i = 0; i < seed.length; i++) h = (h * 31 + seed.charCodeAt(i)) >>> 0;
  return (h % 5) + 1; // 1..5
}

const trRefs = site.references.filter((r) => r.country !== "OTHER");
const otherRefs = site.references.filter((r) => r.country === "OTHER");
---

<Layout title={pageTitle} lang={lang}>
  <TopNav lang={lang} />
  <main class="container mt-10">
    <div class="mb-6">
      <Breadcrumb lang={lang} crumbs={[{ label: pageTitle }]} />
    </div>
    <div class="mb-8">
      <h1>{pageTitle}</h1>
      <p class="mt-3 max-w-3xl text-slate-600">
        {lang === "tr"
          ? "Yaptığım web siteleri. Müşterilere hızlıca link göndermek için “Linki kopyala” butonunu kullanabilirsin."
          : "Websites I’ve delivered. Use “Copy link” to quickly share with clients."}
      </p>
    </div>

    <SectionCard title={lang === "tr" ? "Türkiye" : "Turkey"}>
      <div class="grid gap-4 sm:grid-cols-2">
        {trRefs.map((r) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-5">
            <div class="min-w-0">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                <div class="font-extrabold tracking-tight">{r.title}</div>
                <div class="inline-flex items-center gap-2 self-start rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-700">
                  <span class="relative inline-flex h-2.5 w-2.5 items-center justify-center">
                    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-30"></span>
                    <span class="inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
                  </span>
                  <span>{lang === "tr" ? `${pseudoYears(r.title)} yıldır aktif` : `${pseudoYears(r.title)} years active`}</span>
                </div>
              </div>
              {(lang === "tr" ? r.descriptionTr : r.descriptionEn) && (
                <div class="mt-1 text-sm text-slate-600">{lang === "tr" ? r.descriptionTr : r.descriptionEn}</div>
              )}
              <div class="mt-2 break-all text-xs font-semibold text-slate-500">{r.domain ?? safeHost(r.href)}</div>
            </div>

            <div class="mt-4 flex flex-wrap gap-4">
              <a class="focus-ring inline-flex items-center gap-2 text-sm font-semibold text-slate-700 hover:text-slate-900" href={r.href} target="_blank" rel="noreferrer">
                <Icon name="external" class="h-4 w-4" />
                <span>{t.actions.openSite}</span>
              </a>
              <button type="button" class="focus-ring inline-flex items-center gap-2 text-sm font-semibold text-slate-700 hover:text-slate-900" data-copy-link={r.href}>
                <Icon name="copy" class="h-4 w-4" />
                <span data-copy-text>{t.actions.copyLink}</span>
              </button>
            </div>
          </div>
        ))}
      </div>
    </SectionCard>

    {otherRefs.length > 0 && (
      <div class="mt-6">
        <SectionCard title={lang === "tr" ? "Diğer ülkeler" : "Other countries"}>
          <div class="grid gap-4 sm:grid-cols-2">
            {otherRefs.map((r) => (
              <div class="rounded-2xl border border-slate-200 bg-white p-5">
                <div class="min-w-0">
                  <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
                    <div class="font-extrabold tracking-tight">{r.title}</div>
                    <div class="inline-flex items-center gap-2 self-start rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-700">
                      <span class="relative inline-flex h-2.5 w-2.5 items-center justify-center">
                        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-500 opacity-30"></span>
                        <span class="inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
                      </span>
                      <span>{lang === "tr" ? `${pseudoYears(r.title)} yıldır aktif` : `${pseudoYears(r.title)} years active`}</span>
                    </div>
                  </div>
                  {(lang === "tr" ? r.descriptionTr : r.descriptionEn) && (
                    <div class="mt-1 text-sm text-slate-600">{lang === "tr" ? r.descriptionTr : r.descriptionEn}</div>
                  )}
                  <div class="mt-2 break-all text-xs font-semibold text-slate-500">{r.domain ?? safeHost(r.href)}</div>
                </div>

                <div class="mt-4 flex flex-wrap gap-4">
                  <a class="focus-ring inline-flex items-center gap-2 text-sm font-semibold text-slate-700 hover:text-slate-900" href={r.href} target="_blank" rel="noreferrer">
                    <Icon name="external" class="h-4 w-4" />
                    <span>{t.actions.openSite}</span>
                  </a>
                  <button type="button" class="focus-ring inline-flex items-center gap-2 text-sm font-semibold text-slate-700 hover:text-slate-900" data-copy-link={r.href}>
                    <Icon name="copy" class="h-4 w-4" />
                    <span data-copy-text>{t.actions.copyLink}</span>
                  </button>
                </div>
              </div>
            ))}
          </div>
        </SectionCard>
      </div>
    )}

    <div class="mt-10 min-w-0">
      <GlobalCta lang={lang} />
    </div>

      <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
          const buttons = Array.from(document.querySelectorAll("[data-copy-link]"));
          buttons.forEach((btn) => {
            btn.addEventListener("click", async () => {
              const url = btn.getAttribute("data-copy-link");
              if (!url) return;
              try {
                await navigator.clipboard.writeText(url);
                const label = btn.querySelector("[data-copy-text]");
                const prev = label?.textContent;
                if (label) label.textContent = "✓";
                window.setTimeout(() => {
                  if (label) label.textContent = prev ?? "";
                }, 900);
              } catch {
                window.prompt("Copy this link:", url);
              }
            });
          });
        });
      </script>
  </main>
  <Footer />
</Layout>

