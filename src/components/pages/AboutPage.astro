---
import Layout from "../Layout.astro";
import TopNav from "../TopNav.astro";
import Footer from "../Footer.astro";
import SectionCard from "../SectionCard.astro";
import GlobalCta from "../GlobalCta.astro";
import Breadcrumb from "../Breadcrumb.astro";
import Icon from "../Icon.astro";
import { site } from "../../content/site";
import { ui, type Lang } from "../../content/i18n";

const { lang } = Astro.props as { lang: Lang };
const t = ui[lang];
const pageTitle = lang === "tr" ? "Hakkımda" : "About";
---

<Layout title={pageTitle} lang={lang}>
  <TopNav lang={lang} />
  <main class="container mt-10">
    <div class="mb-6">
      <Breadcrumb lang={lang} crumbs={[{ label: pageTitle }]} />
    </div>
    <div class="mb-8">
      <h1>{pageTitle}</h1>
      <p class="mt-3 max-w-3xl text-slate-600">{lang === "tr" ? site.hero.missionTr : site.hero.missionEn}</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <div id="profile" class="mb-6">
        <SectionCard title={lang === "tr" ? "Profil" : "Profile"}>
          <div class="prose prose-slate max-w-none">
            {(lang === "tr" ? site.hero.bioTr : site.hero.bioEn).map((p) => (
              <p>{p}</p>
            ))}
          </div>
        </SectionCard>
        </div>

        <div id="resume" class="mb-6">
          <SectionCard title={lang === "tr" ? "Özgeçmişim" : "Resume"}>
            <div class="grid gap-3">
              {site.resume.map((r) => (
                <div class="flex gap-3 rounded-xl border border-slate-200 bg-white p-4">
                  <div class="mt-0.5 inline-flex h-10 w-10 flex-none items-center justify-center rounded-xl bg-slate-900 text-white">
                    {r.companyShort ? (
                      <span class="text-sm font-bold">{r.companyShort}</span>
                    ) : (
                      <Icon name={r.icon ?? "briefcase"} class="h-5 w-5" />
                    )}
                  </div>
                  <div class="min-w-0 flex-1">
                    <div class="grid w-full min-w-0 grid-cols-[minmax(0,1fr)_auto] items-start gap-x-3">
                      <div class="min-w-0 font-bold">{r.title}</div>
                      <div class="shrink-0 whitespace-nowrap text-right text-xs font-semibold tabular-nums text-slate-500">{r.range}</div>
                    </div>
                    <div class="mt-0.5 text-sm text-slate-600">{r.company}</div>
                    {(r.employmentType || r.location) && (
                      <div class="mt-1 text-xs text-slate-500">
                        {[r.employmentType, r.location].filter(Boolean).join(" • ")}
                      </div>
                    )}
                    {r.description && <div class="mt-1 text-sm text-slate-600">{r.description}</div>}
                  </div>
                </div>
              ))}
            </div>
          </SectionCard>
        </div>

        <div id="projects" class="mt-6">
          <SectionCard title={lang === "tr" ? "Projeler" : "Projects"}>
            <div class="grid gap-4 sm:grid-cols-2">
              {site.projects.map((p) => (
                <div class="rounded-2xl border border-slate-200 bg-white p-5">
                  <div class="flex items-start gap-3">
                    <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl">
                      {p.logoSrc ? (
                        <img src={p.logoSrc} alt={`${p.title} logo`} class="h-10 w-10 object-contain" loading="lazy" />
                      ) : (
                        <Icon name={p.icon} class="h-8 w-8 text-slate-700" />
                      )}
                    </div>
                    <div>
                      <div class="text-base font-semibold tracking-tight text-slate-900">{p.title}</div>
                      {p.tagline && <div class="mt-1 text-sm font-medium text-slate-600">{p.tagline}</div>}
                      <div class="mt-2 text-sm text-slate-600">{p.description}</div>
                      {p.domain && <div class="mt-2 text-xs font-semibold text-slate-500">{p.domain}</div>}
                      {p.href && (
                        <a
                          class="focus-ring mt-3 inline-flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50"
                          href={p.href}
                          target="_blank"
                          rel="noreferrer"
                        >
                          <span>{lang === "tr" ? "Görüntüle" : "View"}</span>
                          <Icon name="external" class="h-4 w-4" />
                        </a>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </SectionCard>
        </div>

        <div class="mt-6">
          <GlobalCta lang={lang} />
        </div>
      </div>

      <aside class="lg:col-span-5">
        <SectionCard title={lang === "tr" ? "Öne çıkanlar" : "Highlights"}>
          <ul class="space-y-3 text-sm text-slate-700">
            <li class="flex gap-2">
              <span class="mt-0.5 text-sky-700"><Icon name="spark" class="h-5 w-5" /></span>
              <span><strong>6+ yıl</strong> WordPress, <strong>3+ yıl</strong> SEO</span>
            </li>
            <li class="flex gap-2">
              <span class="mt-0.5 text-sky-700"><Icon name="briefcase" class="h-5 w-5" /></span>
              <span><strong>Lead</strong> • UI/UX, görsel kimlik, mentorluk</span>
            </li>
            <li class="flex gap-2">
              <span class="mt-0.5 text-sky-700"><Icon name="badge" class="h-5 w-5" /></span>
              <span><strong>No-code / Low-code</strong> ile hızlı üretim</span>
            </li>
          </ul>

          <div class="mt-5 flex flex-wrap gap-2">
            {site.socials.map((s) => (
              <a
                class="focus-ring inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50"
                href={s.href}
                target="_blank"
                rel="noreferrer"
              >
                <Icon name={s.icon} class="h-5 w-5" />
                <span>{s.label}</span>
              </a>
            ))}
          </div>
        </SectionCard>

        <div class="mt-6">
          <SectionCard title={t.sections.skills}>
            <div class="flex flex-wrap gap-2">
              {site.skills.map((s) => (
                <span class="pill">{s}</span>
              ))}
            </div>
          </SectionCard>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</Layout>

