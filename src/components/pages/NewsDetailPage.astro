---
import Layout from "../Layout.astro";
import TopNav from "../TopNav.astro";
import Footer from "../Footer.astro";
import SectionCard from "../SectionCard.astro";
import Breadcrumb from "../Breadcrumb.astro";
import GlobalCta from "../GlobalCta.astro";
import Icon from "../Icon.astro";
import { site, type ArticleItem } from "../../content/site";
import { ui, type Lang } from "../../content/i18n";

const { lang, article } = Astro.props as { lang: Lang; article: ArticleItem };
const t = ui[lang];

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();
const shareText = lang === "tr" ? article.titleTr : article.titleEn;

const shareLinks = {
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonical)}`,
  x: `https://twitter.com/intent/tweet?url=${encodeURIComponent(canonical)}&text=${encodeURIComponent(shareText)}`,
  whatsapp: `https://wa.me/?text=${encodeURIComponent(`${shareText} ${canonical}`)}`,
};

const pageTitle = lang === "tr" ? article.titleTr : article.titleEn;
const bodyHtml = lang === "tr" ? article.bodyTr : article.bodyEn;

const backHref = lang === "tr" ? "/news" : "/en/news";
const backLabel = lang === "tr" ? "Tüm yazılar" : "All posts";
---

<Layout title={pageTitle} lang={lang}>
  <TopNav lang={lang} />
  <main class="container mt-10">
    <div class="mb-6">
      <Breadcrumb
        lang={lang}
        crumbs={[
          { label: t.sections.news, href: lang === "tr" ? "/news" : "/en/news" },
          { label: pageTitle },
        ]}
      />
    </div>
    <a class="focus-ring inline-flex items-center gap-2 rounded-lg px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50" href={backHref}>
      <span>‹</span>
      <span>{backLabel}</span>
    </a>

    <div class="mt-6">
      <h1 class="max-w-3xl">{pageTitle}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-slate-500">
        <span class="rounded-full bg-slate-100 px-2 py-0.5 font-semibold text-slate-700">{article.category}</span>
        <span>{article.dateISO}</span>
        {article.readingMinutes && <span>• {lang === "tr" ? `${article.readingMinutes} dk okuma` : `${article.readingMinutes} min read`}</span>}
      </div>
      <p class="mt-4 max-w-3xl text-slate-600">{lang === "tr" ? article.excerptTr : article.excerptEn}</p>
    </div>

    <div class="mt-6 grid gap-6 lg:grid-cols-12">
      <article class="min-w-0 lg:col-span-8">
        <section class="card p-6 sm:p-7">
          <div class="prose prose-slate max-w-none" set:html={bodyHtml} />
        </section>
      </article>

      <aside class="min-w-0 lg:col-span-4">
        <SectionCard title={lang === "tr" ? "Paylaş" : "Share"}>
          <div class="flex flex-wrap gap-2">
            <a
              class="focus-ring inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50"
              href={shareLinks.linkedin}
              target="_blank"
              rel="noreferrer"
            >
              <Icon name="linkedin" class="h-5 w-5" />
              <span>LinkedIn</span>
            </a>
            <a
              class="focus-ring inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50"
              href={shareLinks.x}
              target="_blank"
              rel="noreferrer"
            >
              <Icon name="x" class="h-5 w-5" />
              <span>X</span>
            </a>
            <a
              class="focus-ring inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50"
              href={shareLinks.whatsapp}
              target="_blank"
              rel="noreferrer"
            >
              <Icon name="whatsapp" class="h-5 w-5" />
              <span>WhatsApp</span>
            </a>
            <button
              type="button"
              class="focus-ring inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50"
              data-copy-link={canonical}
            >
              <Icon name="copy" class="h-5 w-5" />
              <span data-copy-text>{lang === "tr" ? "Linki kopyala" : "Copy link"}</span>
            </button>
          </div>

          <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-3 text-xs text-slate-600">
            <div class="font-semibold text-slate-800">{lang === "tr" ? "Paylaşım linki" : "Share URL"}</div>
            <div class="mt-1 break-all">{canonical}</div>
          </div>

          <script is:inline>
            document.addEventListener("DOMContentLoaded", () => {
              const btn = document.querySelector("[data-copy-link]");
              if (!btn) return;
              btn.addEventListener("click", async () => {
                const url = btn.getAttribute("data-copy-link");
                if (!url) return;
                try {
                  await navigator.clipboard.writeText(url);
                  const label = btn.querySelector("[data-copy-text]");
                  const prev = label?.textContent;
                  if (label) label.textContent = "✓";
                  window.setTimeout(() => {
                    if (label) label.textContent = prev ?? "";
                  }, 900);
                } catch {
                  window.prompt("Copy this link:", url);
                }
              });
            });
          </script>
        </SectionCard>

        <div class="mt-6">
          <SectionCard title={lang === "tr" ? "Diğer yazılar" : "More posts"}>
            <div class="grid gap-3">
              {site.articles
                .filter((x) => x.slug !== article.slug)
                .slice(0, 3)
                .map((x) => (
                  <a class="focus-ring rounded-xl border border-slate-200 bg-white p-4 hover:bg-slate-50" href={lang === "tr" ? `/news/${x.slug}` : `/en/news/${x.slug}`}>
                    <div class="text-xs text-slate-500">{x.dateISO}</div>
                    <div class="mt-1 text-sm font-semibold text-slate-900">{lang === "tr" ? x.titleTr : x.titleEn}</div>
                    <div class="mt-1 text-sm text-slate-600">{lang === "tr" ? x.excerptTr : x.excerptEn}</div>
                  </a>
                ))}
            </div>
          </SectionCard>
        </div>
      </aside>
    </div>

    <div class="mt-10 min-w-0">
      <GlobalCta lang={lang} />
    </div>
  </main>
  <Footer />
</Layout>

