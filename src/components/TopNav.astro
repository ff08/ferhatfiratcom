---
import { site } from "../content/site";
import Icon from "./Icon.astro";
import { switchLangPath, type Lang, ui } from "../content/i18n";

const { lang } = Astro.props as { lang: Lang };
const t = ui[lang];
const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 border-b border-slate-200 bg-white/80 py-4 backdrop-blur transition-transform duration-200 ease-out will-change-transform"
>
  <div class="container flex items-center justify-between">
    <!-- Primary menu (replaces email in header) -->
    <nav class="hidden items-center gap-1 sm:flex" aria-label="Primary">
      <a
        class="focus-ring rounded-xl px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-100"
        href={lang === "tr" ? "/" : "/en"}
      >
        {t.nav.home}
      </a>
      <a
        class="focus-ring rounded-xl px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-100"
        href={lang === "tr" ? "/about" : "/en/about"}
      >
        {t.nav.about}
      </a>
      <a
        class="focus-ring rounded-xl px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-100"
        href={lang === "tr" ? "/references" : "/en/references"}
      >
        {t.nav.references}
      </a>
      <a
        class="focus-ring rounded-xl px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-100"
        href={`mailto:${t.nav.email}`}
      >
        {t.nav.contact}
      </a>
    </nav>

    <!-- Mobile: show compact brand label -->
    <div class="sm:hidden">
      <span class="max-w-[65vw] truncate text-sm font-semibold text-slate-900">{site.name}</span>
    </div>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-2 sm:flex">
      <a class="focus-ring rounded-lg p-2 text-slate-600 hover:bg-slate-100" href="https://www.linkedin.com/in/ferhatfirat/" target="_blank" rel="noreferrer" aria-label="LinkedIn">
        <Icon name="linkedin" class="h-5 w-5" />
      </a>
      <a class="focus-ring rounded-lg p-2 text-slate-600 hover:bg-slate-100" href="https://instagram.com/_ferhatfirat" target="_blank" rel="noreferrer" aria-label="Instagram">
        <Icon name="instagram" class="h-5 w-5" />
      </a>
      <a class="focus-ring rounded-lg p-2 text-slate-600 hover:bg-slate-100" href="https://upcard.me/ferhat" target="_blank" rel="noreferrer" aria-label="UpCard">
        <Icon name="link" class="h-5 w-5" />
      </a>

      <span class="mx-1 h-5 w-px bg-slate-200"></span>

      <a
        class={`focus-ring rounded-lg px-2 py-1 text-xs font-semibold ${lang === "tr" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100"}`}
        href={switchLangPath(currentPath, "tr")}
        hreflang="tr"
      >
        {t.nav.langTr}
      </a>
      <a
        class={`focus-ring rounded-lg px-2 py-1 text-xs font-semibold ${lang === "en" ? "bg-slate-900 text-white" : "text-slate-700 hover:bg-slate-100"}`}
        href={switchLangPath(currentPath, "en")}
        hreflang="en"
      >
        {t.nav.langEn}
      </a>
    </nav>

    <!-- Mobile hamburger -->
    <button
      type="button"
      class="focus-ring inline-flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-900 shadow-soft hover:bg-slate-50 sm:hidden"
      aria-label="Menu"
      aria-expanded="false"
      data-mobile-menu-button
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M4 7h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <path d="M4 12h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        <path d="M4 17h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu panel -->
  <div class="container sm:hidden">
    <div id="mobile-menu" class="mt-3 hidden rounded-2xl border border-slate-200 bg-white p-4 shadow-soft" data-mobile-menu-panel>
      <div class="grid gap-3">
        <a class="focus-ring inline-flex items-center gap-2 rounded-xl px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50" href={lang === "tr" ? "/" : "/en"}>
          <span>{t.nav.home}</span>
        </a>
        <a class="focus-ring inline-flex items-center gap-2 rounded-xl px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50" href={lang === "tr" ? "/about" : "/en/about"}>
          <span>{t.nav.about}</span>
        </a>
        <a class="focus-ring inline-flex items-center gap-2 rounded-xl px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50" href={lang === "tr" ? "/references" : "/en/references"}>
          <span>{t.nav.references}</span>
        </a>
        <a class="focus-ring inline-flex items-center gap-2 rounded-xl px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50" href={`mailto:${t.nav.email}`}>
          <span>{t.nav.contact}</span>
        </a>

        <div class="h-px bg-slate-200"></div>

        <div class="flex flex-wrap gap-2">
          <a class="focus-ring inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50" href="https://www.linkedin.com/in/ferhatfirat/" target="_blank" rel="noreferrer">
            <Icon name="linkedin" class="h-5 w-5" />
            <span>LinkedIn</span>
          </a>
          <a class="focus-ring inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50" href="https://instagram.com/_ferhatfirat" target="_blank" rel="noreferrer">
            <Icon name="instagram" class="h-5 w-5" />
            <span>Instagram</span>
          </a>
          <a class="focus-ring inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50" href="https://upcard.me/ferhat" target="_blank" rel="noreferrer">
            <Icon name="link" class="h-5 w-5" />
            <span>UpCard</span>
          </a>
        </div>

        <div class="h-px bg-slate-200"></div>

        <div class="flex items-center gap-2">
          <a
            class={`focus-ring rounded-lg px-3 py-2 text-xs font-semibold ${lang === "tr" ? "bg-slate-900 text-white" : "border border-slate-200 bg-white text-slate-700"}`}
            href={switchLangPath(currentPath, "tr")}
            hreflang="tr"
          >
            {t.nav.langTr}
          </a>
          <a
            class={`focus-ring rounded-lg px-3 py-2 text-xs font-semibold ${lang === "en" ? "bg-slate-900 text-white" : "border border-slate-200 bg-white text-slate-700"}`}
            href={switchLangPath(currentPath, "en")}
            hreflang="en"
          >
            {t.nav.langEn}
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const header = document.getElementById("site-header");
    const btn = document.querySelector("[data-mobile-menu-button]");
    const panel = document.querySelector("[data-mobile-menu-panel]");
    if (!header || !btn || !panel) return;

    const updateHeaderHeight = () => {
      const h = header.offsetHeight || 0;
      document.documentElement.style.setProperty("--site-header-h", `${h}px`);
    };
    updateHeaderHeight();
    window.addEventListener("resize", updateHeaderHeight, { passive: true });

    const setOpen = (open) => {
      panel.classList.toggle("hidden", !open);
      btn.setAttribute("aria-expanded", open ? "true" : "false");
    };

    let open = false;
    btn.addEventListener("click", () => {
      open = !open;
      setOpen(open);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        open = false;
        setOpen(false);
      }
    });

    // Hide header on scroll down, show on scroll up
    let lastY = window.scrollY || 0;
    let hidden = false;
    const threshold = 8;

    const setHidden = (next) => {
      hidden = next;
      header.style.transform = hidden ? "translateY(-110%)" : "translateY(0)";
      if (hidden) setOpen(false);
    };

    window.addEventListener(
      "scroll",
      () => {
        const y = window.scrollY || 0;
        const delta = y - lastY;
        if (Math.abs(delta) < threshold) return;

        if (y <= 0) {
          setHidden(false);
          lastY = y;
          return;
        }

        if (delta > 0 && !hidden) setHidden(true);
        if (delta < 0 && hidden) setHidden(false);
        lastY = y;
      },
      { passive: true }
    );
  });
</script>

