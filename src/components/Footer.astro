---
import { site } from "../content/site";
---

<footer class="mt-16 border-t border-slate-200 bg-white">
  <div class="container py-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
      <div>
        <div class="text-sm font-extrabold tracking-tight">{site.name}</div>
        <div class="mt-1 text-sm text-slate-600">{site.footer.copyright}</div>
      </div>
      <div class="flex flex-wrap items-center gap-3 text-sm">
        {site.footer.links.map((l) => (
          <a class="focus-ring rounded-lg px-3 py-2 text-slate-700 hover:bg-slate-50" href={l.href}>
            {l.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>

