---
import "../styles/global.css";
import { site } from "../content/site";
import CookieConsent from "./CookieConsent.astro";
import { switchLangPath } from "../content/i18n";

const { title, description } = Astro.props as {
  title?: string;
  description?: string;
  lang?: "tr" | "en";
};

const metaTitle = title ? `${title} • ${site.name}` : `${site.name} • ${site.domain}`;
const metaDescription =
  description ??
  "Lead Web Designer, No-Code & Low-Code Expert, SEO Specialist. Portfolio, resume, projects and articles.";
const lang = Astro.props.lang ?? "tr";

const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.toString();
const trUrl = Astro.site ? new URL(switchLangPath(Astro.url.pathname, "tr"), Astro.site).toString() : switchLangPath(Astro.url.pathname, "tr");
const enUrl = Astro.site ? new URL(switchLangPath(Astro.url.pathname, "en"), Astro.site).toString() : switchLangPath(Astro.url.pathname, "en");
const ogImage = Astro.site ? new URL("/cover.png", Astro.site).toString() : "/cover.png";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDescription} />
    <title>{metaTitle}</title>
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="tr" href={trUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={trUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <slot />
    <CookieConsent lang={lang} />
  </body>
</html>

