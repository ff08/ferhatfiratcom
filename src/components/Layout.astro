---
import "../styles/global.css";
import { site } from "../content/site";

const { title, description } = Astro.props as {
  title?: string;
  description?: string;
  lang?: "tr" | "en";
};

const metaTitle = title ? `${title} • ${site.name}` : `${site.name} • ${site.domain}`;
const metaDescription =
  description ??
  "Lead Web Designer, No-Code & Low-Code Expert, SEO Specialist. Portfolio, resume, projects and articles.";
const lang = Astro.props.lang ?? "tr";
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDescription} />
    <title>{metaTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <slot />
  </body>
</html>

