---
import { ui, type Lang } from "../content/i18n";

const { lang } = Astro.props as { lang: Lang };
const t = ui[lang];

type Marker = { label: string; x: number; y: number; xMd: number; yMd: number };

// Minimal, stylized "map" canvas (not geospatially accurate).
// Coordinates are percentages. Narrow viewports use looser spacing so pins do not crowd.
const markers: Marker[] = [
  { label: "Mannheim", x: 14, y: 30, xMd: 24, yMd: 38 },
  { label: "İzmir", x: 44, y: 56, xMd: 58, yMd: 58 },
  { label: "Antalya", x: 52, y: 78, xMd: 67, yMd: 76 },
  { label: "Ankara", x: 84, y: 44, xMd: 75, yMd: 52 }
];

const companiesByCity: Record<string, string> = {
  Mannheim: "Creavision GmbH",
  Antalya: "Innodata GmbH",
  "İzmir": "Creaforce Yazılım",
  Ankara: "Here now"
};
---

<div class="relative w-full overflow-hidden rounded-2xl border border-slate-200 bg-white">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_40%,rgba(16,185,129,0.12),transparent_55%),radial-gradient(circle_at_80%_30%,rgba(99,102,241,0.10),transparent_55%)]"></div>
  <div class="absolute inset-0 opacity-[0.65] [background-image:linear-gradient(to_right,rgba(15,23,42,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,0.06)_1px,transparent_1px)] [background-size:40px_40px]"></div>
  <div class="absolute inset-0 opacity-[0.18] [background-image:radial-gradient(rgba(15,23,42,0.18)_1px,transparent_1px)] [background-size:18px_18px]"></div>

  <div class="relative h-[280px] w-full sm:h-[320px]">
    {markers.map((m) => (
      <div
        class="location-marker group absolute"
        style={`--x:${m.x}%;--y:${m.y}%;--x-md:${m.xMd}%;--y-md:${m.yMd}%;`}
      >
        <div class="relative inline-flex items-center gap-2">
          <span class="absolute -inset-3 rounded-full bg-emerald-500/10 opacity-0 blur-md transition group-hover:opacity-100"></span>
          <span class="absolute -inset-2 rounded-full bg-emerald-500/10"></span>
          <span class="relative inline-flex h-3.5 w-3.5 rounded-full border-2 border-white bg-emerald-500 shadow-sm"></span>
          <span class="relative whitespace-nowrap text-xs font-semibold text-slate-700">{m.label}</span>
        </div>

        <div class="mt-2 rounded-xl border border-slate-200 bg-white/90 px-3 py-1 shadow-sm backdrop-blur">
          <div class="text-[10px] font-medium text-slate-500">{companiesByCity[m.label] ?? ""}</div>
        </div>
      </div>
    ))}
  </div>

  <div class="border-t border-slate-200 bg-white px-4 py-3 text-sm text-slate-600 sm:px-5">
    {t.sections.location}: Ankara • Antalya • Mannheim • İzmir
  </div>
</div>

<style>
  .location-marker {
    left: var(--x);
    top: var(--y);
    transform: translate(-50%, -50%);
  }
  @media (min-width: 768px) {
    .location-marker {
      left: var(--x-md);
      top: var(--y-md);
    }
  }
</style>

