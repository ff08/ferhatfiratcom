---
import { ui, type Lang } from "../content/i18n";

const { lang } = Astro.props as { lang: Lang };
const t = ui[lang];

const policiesHref = lang === "tr" ? "/policies#cookies" : "/en/policies#cookies";
---

<div class="hidden" data-cookie-consent>
  <div class="fixed inset-0 z-50 bg-slate-900/30 backdrop-blur-[2px]" data-cookie-overlay></div>
  <div class="fixed inset-x-4 bottom-4 z-50 mx-auto w-auto max-w-xl">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-card">
      <div class="text-sm font-semibold text-slate-900">{lang === "tr" ? "Çerezler" : "Cookies"}</div>
      <p class="mt-2 text-sm text-slate-600">
        {lang === "tr"
          ? "Sitenin düzgün çalışması ve deneyimin iyileştirilmesi için çerezler kullanabiliriz. Detaylar için politikaları inceleyebilirsin."
          : "We may use cookies to ensure the site works properly and to improve the experience. See the policies for details."}
      </p>

      <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
        <a class="focus-ring text-sm font-semibold text-sky-700 hover:underline" href={policiesHref}>
          {lang === "tr" ? "Çerez politikası" : "Cookie policy"}
        </a>

        <div class="flex flex-wrap gap-2">
          <button
            type="button"
            class="focus-ring inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50"
            data-cookie-reject
          >
            {lang === "tr" ? "Reddet" : "Reject"}
          </button>
          <button
            type="button"
            class="focus-ring inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
            data-cookie-accept
          >
            {lang === "tr" ? "Kabul et" : "Accept"}
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const root = document.querySelector("[data-cookie-consent]");
    if (!root) return;

    const overlay = root.querySelector("[data-cookie-overlay]");
    const btnAccept = root.querySelector("[data-cookie-accept]");
    const btnReject = root.querySelector("[data-cookie-reject]");
    if (!overlay || !btnAccept || !btnReject) return;

    const KEY = "ff_cookie_consent_v1";
    const existing = window.localStorage.getItem(KEY);
    if (existing === "accepted" || existing === "rejected") return;

    root.classList.remove("hidden");

    const close = (value) => {
      try {
        window.localStorage.setItem(KEY, value);
      } catch {}
      root.classList.add("hidden");
    };

    btnAccept.addEventListener("click", () => close("accepted"));
    btnReject.addEventListener("click", () => close("rejected"));
    overlay.addEventListener("click", () => close("rejected"));
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close("rejected");
    });
  });
</script>

